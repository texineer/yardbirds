# BleacherBox Configuration

# Server port
PORT=3001

# Database path (optional, defaults to data/bleacherbox.db)
# DB_PATH=/opt/bleacherbox/data/bleacherbox.db

# Year for scraping (optional, defaults to current year)
# YEAR=2026

# Session secret for auth (required in production)
SESSION_SECRET=change-me-to-a-random-string

# ElevenLabs PA Announcer voice (optional — enables ballpark-quality player announcements)
# Sign up free at https://elevenlabs.io — free tier covers a full team many times over
# ELEVENLABS_API_KEY=your-api-key-here
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB  # "Adam" — deep, authoritative (default)

# Teams are now configured in the database via POST /api/teams
# No per-team env vars needed — add teams via the API:
#
# curl -X POST http://localhost:3001/api/teams \
#   -H "Content-Type: application/json" \
#   -d '{"slug":"yardbirds","pgOrgId":50903,"pgTeamId":276649,"name":"RR Yardbirds 14U","ageGroup":"14U","ftTeamUuid":"cc705482-...","ftSeasons":"2026-baseball"}'
